{
  "name": "riichi-mahjong-score",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:gh": "tsc --noEmit && vite build --base /riichiMahjong_cal/",
    "preview": "vite preview",
    "preview:gh": "vite preview --base /riichiMahjong_cal/",
    "deploy": "npm run build:gh && npx --yes gh-pages -d dist"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "gh-pages": "^6.1.1",
    "typescript": "^5.2.2",
    "vite": "^4.5.3"
  }
}
